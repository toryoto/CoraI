generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  clerkId       String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  threads       Thread[]
}

model Thread {
  id          String    @id @default(cuid())
  title       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  
  @@index([userId])
}

model Conversation {
  id            String    @id @default(cuid())
  name          String?   // 会話/ブランチの名前
  isDefault     Boolean   @default(false) // デフォルト（最初の）会話かどうか
  threadId      String
  thread        Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  parentId      String?   // 親会話ID
  parent        Conversation? @relation("ConversationBranch", fields: [parentId], references: [id])
  branches      Conversation[] @relation("ConversationBranch")
  
  // 分岐元メッセージの情報
  forkMessageId String?   // どのメッセージから分岐したか
  
  messages      Message[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([threadId])
  @@index([parentId])
}

model Message {
  id            String    @id @default(cuid())
  role          String    // user or assistant
  content       String
  sequence      Int
  
  conversationId String
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
  
  @@unique([conversationId, sequence]) // 同じ会話内では順序が一意
  @@index([conversationId])
}